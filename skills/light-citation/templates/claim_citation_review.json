{
  "schema": "light.claim_citation_review.v1",
  "reviews": [
    {
      "claim_id": "C-01",
      "claim_locator": "draft.md:L12",
      "claim_text": "{{exact claim}}",
      "claim_text_sha256": "sha256:replace-with-current-claim-text-hash",
      "reviewed_claim_sha256": "sha256:replace-with-hash-of-claim-text-reviewed",
      "citekey": "smith2024dataset",
      "work_identifier": "10.xxxx/example",
      "access": "FULLTEXT",
      "source_locator": "{{real PDF p. 7 / section / figure / table / abstract; no placeholder in final}}",
      "source_excerpt": "{{source passage or precise paraphrase}}",
      "source_evidence_sha256": "sha256:replace-with-64-hex",
      "support_verdict": "supports",
      "support_scope": "FULLTEXT_LOCATOR",
      "allowed_support_scopes": [
        "FULLTEXT_LOCATOR",
        "ABSTRACT_EXPLICIT",
        "BACKGROUND_ONLY",
        "NOT_SUPPORTED"
      ],
      "abstract_claim_explicit": false,
      "allowed_verdicts": [
        "supports",
        "partial",
        "related_only",
        "unsupported",
        "review_required"
      ],
      "reviewer": "{{human or named review process}}",
      "reviewed_at": "{{already-occurred ISO-8601 datetime}}",
      "note": "{{scope, direction, population, metric and caveats}}"
    }
  ]
}
