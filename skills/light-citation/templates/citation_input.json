{
  "schema": "light.citation_input.v1",
  "project": "{{project}}",
  "references": [
    {
      "citekey": "smith2024dataset",
      "doi": "10.xxxx/example",
      "arxiv": "",
      "pmid": "",
      "isbn": "",
      "url": "https://doi.org/10.xxxx/example",
      "title": "{{title exactly as cited}}",
      "authors": [
        "{{family name}}"
      ],
      "year": 2024,
      "source_locator": "{{PDF p. 7 / section / figure / table / abstract}}",
      "source_excerpt": "{{short paraphrase or excerpt needed for support review}}",
      "support_verdict": "review_required",
      "reviewed_claim_sha256": "sha256:replace-with-current-claim-text-hash-when-used-from-claim-map",
      "support_scope": "{{FULLTEXT_LOCATOR / ABSTRACT_EXPLICIT / BACKGROUND_ONLY / NOT_SUPPORTED}}",
      "abstract_claim_explicit": false,
      "review_note": "{{why this source supports / only relates to / fails to support the claim}}"
    }
  ]
}
