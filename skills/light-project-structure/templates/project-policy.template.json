{
  "schema": "light.project-structure.policy.v1",
  "project": {
    "project_type": "UNKNOWN",
    "artifact_types": ["UNKNOWN"],
    "profile_selection_reason": "UNKNOWN",
    "deliverables": "UNKNOWN",
    "compute_environment": "UNKNOWN",
    "data_volume": "UNKNOWN",
    "remote_storage": "UNKNOWN",
    "collaborators": "UNKNOWN",
    "ci": "UNKNOWN",
    "license": "UNKNOWN",
    "retention": "UNKNOWN"
  },
  "rules": [
    {
      "glob": "tests/fixtures/**",
      "max_bytes": 1048576,
      "owner": "test-suite",
      "producer": "maintainer",
      "recomputability": "source",
      "sensitivity": "public",
      "classification": "test-fixture",
      "git_policy": "track",
      "target": "tests/fixtures/"
    },
    {
      "glob": "tests/golden/**",
      "owner": "test-suite",
      "producer": "approved-reference-run",
      "recomputability": "reference-output",
      "sensitivity": "public",
      "classification": "golden-file",
      "git_policy": "track",
      "target": "tests/golden/"
    },
    {
      "glob": "models/**",
      "min_bytes": 10485760,
      "owner": "UNKNOWN",
      "producer": "experiment-run",
      "recomputability": "recomputable",
      "sensitivity": "UNKNOWN",
      "classification": "large-model",
      "git_policy": "dvc",
      "target": "UNKNOWN"
    }
  ]
}
