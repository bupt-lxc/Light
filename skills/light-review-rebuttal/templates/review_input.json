{
  "schema": "light.review_rebuttal_input.v2",
  "project": "{{project}}",
  "venue_handoff": "{{selected-venue-handoff.json}}",
  "venue_context": "{{review-rebuttal-context.json}}",
  "paper_claims": "{{claim_argument_plan.json}}",
  "evidence_strength": "{{evidence_strength.json}}",
  "citation_registry": "{{citation-registry.json}}",
  "reviews": [
    {
      "source_id": "review-round1-r1",
      "source_kind": "user_supplied",
      "source_url": null,
      "captured_at": "{{ISO-8601}}",
      "access_status": "AVAILABLE",
      "access_reason": null,
      "round": 1,
      "reviewer_id": "R1",
      "decision": "{{Reject | Major Revision | Minor Revision | UNKNOWN}}",
      "meta_review": "{{verbatim meta-review or null}}",
      "attachments": [],
      "raw_text": "{{verbatim reviewer text}}",
      "raw_sha256": "{{sha256 of raw_text}}",
      "atoms": [
        {
          "issue_id": "R1-1",
          "raw_span": "{{exact contiguous span copied from raw_text}}",
          "source_span": {
            "start": "{{0-based start offset in raw_text}}",
            "end": "{{exclusive end offset in raw_text}}",
            "text": "{{exact contiguous span copied from raw_text}}",
            "sha256": "{{sha256 of source_span.text}}"
          },
          "issue_type": "request",
          "root_cause": "experiment",
          "severity": "major",
          "interpretation": "{{interpretation layer; never replace raw_span}}",
          "rejection_driving": false,
          "rejection_evidence": null,
          "claim_ids": [],
          "evidence_claim_ids": [],
          "action": {
            "strategy": "acknowledge_and_fix",
            "action_kind": "experiment",
            "description": "{{atomic action}}",
            "owner": "{{owner}}",
            "status": "PLANNED",
            "change_locator": null,
            "artifact_path": null,
            "run_provenance": null,
            "new_citation_work_ids": [],
            "response_text": "{{draft that does not claim planned work is done}}"
          }
        }
      ]
    }
  ]
}
