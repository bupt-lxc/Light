{
  "schema": "light.run_manifest.v3",
  "run_id": "{{matrix_row}}__seed-{{seed}}__{{attempt}}",
  "matrix_row": "{{EXP-01}}",
  "status": "completed",
  "termination": {
    "reason": "natural_exit",
    "exit_code": 0,
    "signal": null
  },
  "seed": {
    "role": "fixed_repro",
    "value": 42
  },
  "command": [
    "python",
    "-m",
    "src.train",
    "--config",
    "config.json"
  ],
  "started_at": "{{ISO-8601 with timezone}}",
  "ended_at": "{{ISO-8601 with timezone}}",
  "config": {
    "path": "config.json",
    "sha256": "{{64-hex}}"
  },
  "environment": {
    "path": "environment.json",
    "sha256": "{{64-hex}}"
  },
  "code": {
    "commit": "{{git commit}}",
    "dirty": false,
    "diff_sha256": null,
    "files": [
      {
        "path": "src/train.py",
        "sha256": "{{64-hex}}"
      }
    ]
  },
  "inputs": [
    {
      "role": "data",
      "path": "data/input.csv",
      "sha256": "{{64-hex}}",
      "source_revision": "{{provider revision/version}}"
    }
  ],
  "artifacts": {
    "stdout": {
      "path": "stdout.log",
      "sha256": "{{64-hex}}"
    },
    "stderr": {
      "path": "stderr.log",
      "sha256": "{{64-hex}}"
    },
    "raw_metrics": {
      "path": "raw_metrics.jsonl",
      "sha256": "{{64-hex}}"
    },
    "predictions": {
      "path": "predictions.csv",
      "sha256": "{{64-hex}}"
    },
    "test_evidence": {
      "path": "test_evidence.json",
      "sha256": "{{64-hex}}"
    },
    "guardrail_evidence": {
      "path": "guardrails.json",
      "sha256": "{{64-hex}}"
    },
    "failure": null
  },
  "completion": {
    "status": "PASS",
    "oracle": [
      "declared test suite passed",
      "required raw outputs exist and are parseable"
    ],
    "evidence_artifacts": [
      "test_evidence",
      "raw_metrics",
      "predictions",
      "guardrail_evidence"
    ]
  },
  "reproducibility": {
    "pair_id": "{{matrix_row}}__seed-42",
    "comparison_role": "first",
    "compare_artifacts": [
      "predictions",
      "raw_metrics"
    ]
  },
  "notes": []
}
