{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://light.local/schemas/experiment-config.v1.json",
  "title": "Light experiment row config",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "matrix_row",
    "frozen_plan_sha256",
    "seed",
    "data",
    "features",
    "model",
    "evaluation",
    "runtime"
  ],
  "properties": {
    "matrix_row": {"type": "string", "minLength": 1},
    "frozen_plan_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "seed": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "value"],
      "properties": {
        "role": {"enum": ["fixed_repro", "randomness_estimation"]},
        "value": {"type": "integer", "minimum": 0}
      }
    },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "source_revision", "split_id"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "source_revision": {"type": "string", "minLength": 1},
        "split_id": {"type": "string", "minLength": 1}
      }
    },
    "features": {
      "type": "object",
      "additionalProperties": false,
      "required": ["baseline", "candidate_additions"],
      "properties": {
        "baseline": {"type": "array", "items": {"type": "string"}, "minItems": 1},
        "candidate_additions": {"type": "array", "items": {"type": "string"}}
      }
    },
    "model": {"type": "object"},
    "evaluation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["unit", "primary_metric", "folds"],
      "properties": {
        "unit": {"type": "string", "minLength": 1},
        "primary_metric": {"type": "string", "minLength": 1},
        "folds": {"type": "integer", "minimum": 2}
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["device", "dtype", "mixed_precision"],
      "properties": {
        "device": {"type": "string", "minLength": 1},
        "dtype": {"type": "string", "minLength": 1},
        "mixed_precision": {"type": "boolean"}
      }
    }
  }
}
