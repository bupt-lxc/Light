    "light-consistency": {
      "role": "overlay",
      "stage": null,
      "emits_findings": true,
      "consumer": "checkpoint selected by the current pipeline stage",
      "decision_stop": "which source is canonical"
    },
    "light-research-ethics": {
      "role": "overlay",
      "stage": null,
      "emits_findings": true,
      "consumer": "checkpoint selected by the current pipeline stage",
      "decision_stop": "human ethics and integrity review"
    },
    "light-file-reading": {
      "role": "overlay-off-dag",
      "stage": null,
      "emits_findings": false,
      "consumer": "requesting skill",
      "decision_stop": "coverage or extraction limitation"
    },
    "light-frontend-design": {
      "role": "engineering-off-dag",
      "stage": null,
      "emits_findings": false,
      "consumer": "requested software project",
      "decision_stop": "visual direction and stack choice"
    },
    "light-system-design": {
      "role": "engineering-off-dag",
      "stage": null,
      "emits_findings": false,
      "consumer": "requested software project",
      "decision_stop": "architecture option and exact mutation authorization"
    },
    "light-patent-disclosure": {
      "role": "engineering-off-dag",
      "stage": null,
      "emits_findings": false,
      "consumer": "requested IP handoff package",
      "decision_stop": "jurisdiction, public disclosure, ownership and attorney review"
    },
    "light-software-copyright": {
      "role": "engineering-off-dag",
      "stage": null,
      "emits_findings": false,
      "consumer": "requested software copyright material package",
      "decision_stop": "application fields, code selection, secrets and final export"
    }
