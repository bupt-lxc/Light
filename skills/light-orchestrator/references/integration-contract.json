{
  "schema": "light.integration.v1",
  "skills": {
    "light-orchestrator": {
      "role": "controller",
      "stage": null,
      "emits_findings": false,
      "consumer": "user and passport",
      "decision_stop": "direction, idea, plan, reroute, venue, delivery"
    },
    "light-literature-search": {
      "role": "pipeline",
      "stage": 1,
      "emits_findings": true,
      "consumer": "idea-generation and idea-critique",
      "decision_stop": "direction choice"
    },
    "light-data-engineering": {
      "role": "pipeline",
      "stage": 2,
      "emits_findings": true,
      "consumer": "stage-2 checkpoint and stage-3 admission",
      "decision_stop": "data insufficiency admission hold"
    },
    "light-idea-generation": {
      "role": "pipeline",
      "stage": 3,
      "emits_findings": true,
      "consumer": "idea-critique",
      "decision_stop": "idea candidate choice"
    },
    "light-idea-critique": {
      "role": "pipeline",
      "stage": 4,
      "emits_findings": true,
      "consumer": "stage-4 checkpoint and reroute",
      "decision_stop": "idea approval or 4-to-3 rework"
    },
    "light-research-plan": {
      "role": "pipeline",
      "stage": 5,
      "emits_findings": true,
      "consumer": "stage-5 checkpoint",
      "decision_stop": "plan authorization"
    },
    "light-experiment-coding": {
      "role": "pipeline",
      "stage": 6,
      "emits_findings": true,
      "consumer": "stage-6 checkpoint and result-analysis",
      "decision_stop": "unsafe or irreproducible execution"
    },
    "light-result-analysis": {
      "role": "pipeline",
      "stage": 7,
      "emits_findings": true,
      "consumer": "stage-7 checkpoint, paper-writing and figure",
      "decision_stop": "7-to-5 or 7-to-6 rework"
    },
    "light-paper-writing": {
      "role": "pipeline",
      "stage": 8,
      "emits_findings": true,
      "consumer": "stage-8 checkpoint, citation and figure",
      "decision_stop": "8-to-7 rework; 8-to-6 only by user override"
    },
    "light-figure": {
      "role": "pipeline",
      "stage": 9,
      "emits_findings": true,
      "consumer": "stage-9 checkpoint and typesetting",
      "decision_stop": "9-to-7 evidence rework"
    },
    "light-citation": {
      "role": "pipeline",
      "stage": 10,
      "emits_findings": true,
      "consumer": "stage-10 checkpoint and typesetting",
      "decision_stop": "repair inside stage 10"
    },
    "light-typesetting": {
      "role": "pipeline",
      "stage": 11,
      "emits_findings": true,
      "consumer": "stage-11 checkpoint and venue-matching",
      "decision_stop": "repair inside stage 11"
    },
    "light-venue-matching": {
      "role": "pipeline",
      "stage": 12,
      "emits_findings": true,
      "consumer": "user decision packet only",
      "decision_stop": "venue choice; no STAGE_GATES or ROUTES entry"
    },
    "light-review-rebuttal": {
      "role": "pipeline",
      "stage": 13,
      "emits_findings": true,
      "consumer": "stage-13 checkpoint and reroute",
      "decision_stop": "13-to-3, 13-to-5 or 13-to-8 rework"
    },
    "light-memory-pm": {
      "role": "overlay",
      "stage": null,
      "emits_findings": true,
      "consumer": "handoff or delivery ledger audit on demand",
      "decision_stop": "archive, authority change or ledger repair"
    },
    "light-project-structure": {
      "role": "overlay-off-dag",
      "stage": null,
      "emits_findings": false,
      "consumer": "local project tree only",
      "decision_stop": "authorized move or rollback"
