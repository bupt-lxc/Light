{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://light.local/schemas/passport-v3.json",
  "title": "Light orchestrator passport v3",
  "type": "object",
  "required": [
    "schema",
    "project",
    "pipeline",
    "created",
    "updated",
    "current_stage",
    "state_revision",
    "state_hash",
    "evidence_state",
    "next_action",
    "delivery_status",
    "stages"
  ],
  "properties": {
    "schema": {"const": "light.passport.v3"},
    "project": {"type": "string", "minLength": 1},
    "pipeline": {"type": "string", "minLength": 1},
    "created": {"type": "string", "minLength": 1},
    "updated": {"type": "string", "minLength": 1},
    "current_stage": {"type": "integer", "minimum": 0, "maximum": 13},
    "state_revision": {"type": "integer", "minimum": 1},
    "state_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "evidence_state": {
      "enum": ["VERIFIED", "PLANNED", "UNKNOWN", "UNAVAILABLE", "FAILED"]
    },
    "next_action": {"type": "string"},
    "delivery_status": {"enum": ["IN_PROGRESS", "DELIVERED"]},
    "delivery_authorization_id": {"type": ["string", "null"]},
    "known_limitations": {"type": "array", "items": {"type": "string"}},
    "stages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["stage", "skill", "input", "output"],
        "properties": {
          "stage": {"type": "integer", "minimum": 1, "maximum": 13},
          "skill": {"type": "string"},
          "status": {
            "enum": ["not_started", "in_progress", "delivered", "gate_failed", "needs_rework"]
          },
          "node_kind": {"const": "pipeline"},
          "evidence_state": {
            "enum": ["VERIFIED", "PLANNED", "UNKNOWN", "UNAVAILABLE", "FAILED"]
          },
          "revision_rounds": {"type": "integer", "minimum": 0, "maximum": 2},
          "depends_on": {"type": "array", "items": {"type": "integer"}},
          "artifacts": {"type": "array", "items": {"type": "string"}},
          "inputs_fingerprint": {"type": "string"},
          "back_edges": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "from",
                "to",
                "root_cause",
                "evidence_ptr",
                "round",
                "by",
                "at",
                "authorization_id"
              ]
            }
          }
        }
      }
    }
  }
}
