{
  "schema": "light.typesetting_input.v1",
  "project": "replace-me",
  "manuscript": {
    "path": "paper.tex",
    "target": "paper.tex",
    "source": {
      "producer": "paper-writing",
      "artifact": "draft.tex"
    },
    "source_files": []
  },
  "figures": [
    {
      "id": "F1",
      "path": "figure-delivery/result.pdf",
      "target": "figures/result.pdf",
      "source_manifest": "figure-delivery/manifest.json",
      "dimensions": {
        "width_mm": null,
        "height_mm": null,
        "dpi": null
      }
    }
  ],
  "citation": {
    "delivery": "citation-delivery/delivery.json",
    "bib_target": "references.bib"
  },
  "venue_profile": {
    "schema": "light.typesetting_venue_profile.v1",
    "name": "user-supplied-or-current-official-profile",
    "source": {
      "kind": "user_input",
      "url": null,
      "checked_at": "YYYY-MM-DD",
      "notes": "Do not invent a limit when no source is available."
    },
    "rules": {
      "engine": "auto",
      "bibliography_backend": "bibtex",
      "compile_tool": "auto",
      "compile_timeout_seconds": 300,
      "double_blind": false,
      "max_pages": 0,
      "page_scope": "unspecified",
      "required_documentclass": null,
      "required_packages": [],
      "expected_page_size": null,
      "require_embedded_fonts": false
    }
  },
  "output_dir": "typesetting-build"
}
