{
  "schema": "light.research_failure_tree.v1",
  "project": "{{project_id}}",
  "plan_state": "DRAFT",
  "hypotheses": [
    {
      "id": "H1",
      "claim": "{{可证伪 claim}}",
      "primary_endpoint": {
        "metric": "{{主指标}}",
        "unit": "{{单位}}",
        "timepoint": "{{冻结评测时间点/数据版本}}"
      },
      "branches": {
        "success": {
          "condition": "{{如 F1 提升 >= 3pp 且 q < 0.05}}",
          "action_kind": "PROCEED_CONFIRMATORY",
          "claim_impact": "{{允许的 confirmatory claim 边界}}"
        },
        "failure": {
          "condition": "{{如 F1 提升 < 1pp 或 q >= 0.05}}",
          "action_kind": "REPLAN",
          "claim_impact": "{{不得写 superiority；回 research-plan / 降 claim}}"
        },
        "inconclusive": {
          "condition": "{{如 95% CI 跨过 SESOI 或 precision 不足}}",
          "action_kind": "REPORT_INCONCLUSIVE",
          "claim_impact": "{{只能写无结论/精度不足，不写支持}}"
        }
      }
    }
  ],
  "guardrails": [
    {
      "id": "G1",
      "metric": "{{质量/安全/counter-metric}}",
      "direction": ">=",
      "threshold": "{{如 0.70}}",
      "monitored_during": "{{哪个实验/阶段监控}}",
      "kill_action": "{{触发后停止/降 claim/补实验的动作}}",
      "claim_impact": "{{guardrail 未过时哪些宣称禁止}}"
    }
  ],
  "stopping": {
    "rule": "{{fixed-N / sequential / budget-limited 的规则}}",
    "limit": "{{如 N=240 independent subjects 或 GPU<=80h}}",
    "action_on_exhaustion": "{{资源/样本/时间耗尽时默认动作}}"
  },
  "amendment_policy": {
    "post_data_changes": "EXPLORATORY_ONLY",
    "authorization_required": true,
    "deviation_log": "{{.light/deviations.md 或 registry amendment locator}}"
  },
  "authorization": {
    "actor": "",
    "authorization_id": "",
    "authorized_at": "",
    "plan_sha256": ""
  }
}
