{
  "schema": "light.research_plan_package.v1",
  "project": "{{project_id}}",
  "artifacts": {
    "research_plan": "PROJECT_PLAN.md",
    "experiment_matrix": "experiments/experiment_matrix.md",
    "target_chain_report": ".light/target_chain_report.json",
    "failure_tree_report": ".light/failure_tree_report.json",
    "plan_findings": ".light/plan_findings.json",
    "preregistration": "preregistration.md",
    "reproducibility_checklist": "reproducibility-checklist.md"
  },
  "handoff": {
    "next_stage": "experiment-coding",
    "user_authorized": true,
    "authorized_at": "{{YYYY-MM-DDTHH:MM:SS+08:00}}",
    "claim_scope": "{{confirmatory/secondary/exploratory 的宣称边界；未修 warning 如何降 claim}}"
  },
  "warning_decisions": [
    {
      "source": "{{如 ablation_isolation / statistical_power / matrix_lint}}",
      "decision": "{{修复、暂缓、转 exploratory、降低 claim 或补实验的决策}}",
      "claim_impact": "{{这条 warning 对论文/竞赛/产品宣称的影响}}",
      "authorized_by": "user"
    }
  ]
}
