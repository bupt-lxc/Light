{
  "schema": "light.paper_claims.v1",
  "project": "{{project}}",
  "draft_path": "{{draft.md}}",
  "draft_sha256": "{{sha256 of the exact UTF-8 draft text currently being checked}}",
  "venue": {
    "name": "{{target venue}}",
    "requirements_source": "{{official URL or versioned local copy}}",
    "checked_at": "{{YYYY-MM-DD}}"
  },
  "source_artifacts": [
    {
      "artifact_id": "analysis-evidence",
      "path": "{{analysis_out/evidence_strength.json}}",
      "role": "statistical_evidence",
      "sha256": "{{real sha256 if available}}",
      "run": "{{run manifest or empty when unavailable}}",
      "commit": "{{real commit or empty when unavailable}}",
      "owner": "{{owner}}",
      "captured_at": "{{ISO-8601}}"
    }
  ],
  "claims": [
    {
      "claim_id": "C-01",
      "text": "{{exactly one unique sentence copied from the draft}}",
      "locator": "{{draft.md:L12 or section/paragraph anchor}}",
      "claim_type": "RESULT",
      "evidence_claim_ids": [
        "{{claim_id exactly as emitted in evidence_strength.json}}"
      ],
      "source_locators": [
        "{{analysis_out/evidence_strength.json#claim-id}}",
        "{{analysis_out/summary.json#field or claim_evidence_table.md row}}"
      ],
      "result_card": {
        "claim_id": "{{claim_id exactly as emitted in light.result_card.v1}}",
        "locator": "{{analysis_out/result-card-C-01.json}}",
        "sha256": "{{real sha256 of result card JSON}}",
        "decision": "CLAIM_READY",
        "language_strength": "{{result_card.language.strength}}",
        "guardrail_summary": {
          "required": true,
          "status": "{{PASS|WARN|FAIL|UNKNOWN}}",
          "claim_impact": "{{how guardrail/counter-metric limits or permits this manuscript claim}}",
          "evidence_locator": "{{analysis_out/guardrails.json#id or result-card guardrail check locator}}",
          "not_applicable_rationale": "{{only when required=false}}"
        }
      },
      "sections": [
        "abstract",
        "introduction",
        "results",
        "conclusion"
      ],
      "citation_candidates": [],
      "figure_requirements": [],
      "limitations": [
        "{{scope or uncertainty boundary}}"
      ],
      "status": "supported",
      "post_hoc": false,
      "owner": "{{owner}}",
      "updated_at": "{{ISO-8601}}"
    }
  ]
}
